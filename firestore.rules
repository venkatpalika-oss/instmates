rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================= AUTH HELPERS =================
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ================= USERS =================
    match /users/{userId} {
      // READ: allow logged-in users to list users
      allow read: if isSignedIn();

      // WRITE: only owner can update own user doc
      allow create, update: if isOwner(userId);

      // NO DELETE
      allow delete: if false;
    }

    // ================= PROFILES =================
    match /profiles/{userId} {
      // ALL USERS (SIGNED IN OR NOT) CAN SEE PROFILES
      allow read: if true;

      // ONLY OWNER CAN WRITE
      allow create, update: if isOwner(userId);

      // NO DELETE
      allow delete: if false;
    }

    // ================= POSTS =================
    match /posts/{postId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.content is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.reactions == {"agree": 0, "faced": 0, "helpful": 0}
        && request.resource.data.votedBy == {};

      // Owner can edit their own post content
      allow update: if isSignedIn()
        && isOwner(resource.data.uid)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['content', 'editedAt']);

      // One-time reaction vote (no undo, matches app UI)
      allow update: if isSignedIn()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['reactions', 'votedBy'])
        && resource.data.votedBy[request.auth.uid] != true
        && request.resource.data.votedBy[request.auth.uid] == true
        && request.resource.data.votedBy.size() == resource.data.votedBy.size() + 1
        && (
          (request.resource.data.reactions.agree == resource.data.reactions.agree + 1
            && request.resource.data.reactions.faced == resource.data.reactions.faced
            && request.resource.data.reactions.helpful == resource.data.reactions.helpful)
          || (request.resource.data.reactions.faced == resource.data.reactions.faced + 1
            && request.resource.data.reactions.agree == resource.data.reactions.agree
            && request.resource.data.reactions.helpful == resource.data.reactions.helpful)
          || (request.resource.data.reactions.helpful == resource.data.reactions.helpful + 1
            && request.resource.data.reactions.agree == resource.data.reactions.agree
            && request.resource.data.reactions.faced == resource.data.reactions.faced)
        );

      allow delete: if false;

      // ================= COMMENTS =================
      match /comments/{commentId} {
        allow read: if true;

        allow create: if isSignedIn()
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.content is string
          && request.resource.data.createdAt is timestamp;

        allow update, delete: if false;

        // ================= REPLIES =================
        match /replies/{replyId} {
          allow read: if true;

          allow create: if isSignedIn()
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.content is string
            && request.resource.data.createdAt is timestamp;

          allow update, delete: if false;
        }
      }
    }
  }
}
